# pg_query_optimizer_tracer extension
# PostgreSQL Query Optimizer Tracer Extension

comment = 'Query optimizer tracer for PG Query Visualizer'
default_version = '1.0.0'
module_pathname = '$libdir/pg_query_optimizer_tracer'
relocatable = false
superuser = true
schema = public

# Required PostgreSQL version
requires = ''

# Configuration
config = true
