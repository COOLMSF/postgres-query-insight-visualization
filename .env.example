# PG Query Visualizer - Environment Configuration

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pg_query_demo

# Application ID (for session management)
VITE_APP_ID=pg_query

# Analytics Configuration (optional)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# Forge API Configuration (for external services)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
